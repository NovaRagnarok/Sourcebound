APP_NAME=source-aware-worldbuilding
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_STATE_BACKEND=postgres
APP_TRUTH_BACKEND=postgres
APP_DATA_DIR=./data/dev
APP_SQLITE_PATH=./runtime/sourcebound.db
APP_POSTGRES_DSN=postgresql://saw:saw@localhost:5432/saw
APP_POSTGRES_SCHEMA=sourcebound
APP_UI_ENABLED=true
APP_STRICT_STARTUP_CHECKS=false
APP_JOB_WORKER_ENABLED=true
APP_JOB_POLL_INTERVAL_SECONDS=0.25
APP_JOB_STALE_TIMEOUT_SECONDS=15
APP_ALLOW_QUEUED_JOBS_WITHOUT_WORKER=false
APP_RESEARCH_DEFAULT_ADAPTER_ID=web_open
APP_RESEARCH_TOTAL_FETCH_TIME_SECONDS=90
APP_RESEARCH_PER_HOST_FETCH_CAP=3
APP_RESEARCH_RETRY_ATTEMPTS=3
APP_RESEARCH_RETRY_BACKOFF_BASE_MS=250
APP_RESEARCH_RETRY_BACKOFF_MAX_MS=2000
APP_RESEARCH_RESPECT_ROBOTS=true
APP_RESEARCH_USER_AGENT=SourceboundResearchScout/0.2 (+https://github.com/NovaRagnarok/Sourcebound)
APP_RESEARCH_SEARCH_PROVIDERS=

ZOTERO_LIBRARY_TYPE=user
ZOTERO_LIBRARY_ID=
ZOTERO_COLLECTION_KEY=
ZOTERO_API_KEY=
ZOTERO_BASE_URL=https://api.zotero.org

GRAPH_RAG_ROOT=./runtime/graphrag
GRAPH_RAG_ENABLED=true
GRAPH_RAG_MODE=in_process
GRAPH_RAG_ARTIFACTS_DIR=
LLM_API_KEY=

WIKIBASE_BASE_URL=
WIKIBASE_API_URL=
WIKIBASE_USERNAME=
WIKIBASE_PASSWORD=
WIKIBASE_PROPERTY_MAP=

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=approved_claims
QDRANT_ENABLED=true
RESEARCH_SEMANTIC_ENABLED=true
RESEARCH_QDRANT_COLLECTION=research_findings
RESEARCH_SEMANTIC_DUPLICATE_THRESHOLD=0.9
RESEARCH_SEMANTIC_NOVELTY_FLOOR=0.1
RESEARCH_SEMANTIC_RERANK_WEIGHT=0.05
