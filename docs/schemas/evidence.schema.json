{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/evidence.schema.json",
  "title": "EvidenceSnippet",
  "type": "object",
  "required": [
    "evidence_id",
    "source_id",
    "locator",
    "text"
  ],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "locator": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "text_unit_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "span_start": {
      "type": [
        "integer",
        "null"
      ]
    },
    "span_end": {
      "type": [
        "integer",
        "null"
      ]
    },
    "notes": {
      "type": "string"
    },
    "checksum": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
